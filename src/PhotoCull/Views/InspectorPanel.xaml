<UserControl x:Class="PhotoCull.Views.InspectorPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:conv="clr-namespace:PhotoCull.Converters"
             Background="Transparent">
    <UserControl.Resources>
        <conv:ByteArrayToImageSourceConverter x:Key="ImgConv"/>
        <conv:CullStatusToColorConverter x:Key="StatusColor"/>
        <conv:RatingToStarsConverter x:Key="StarConv"/>
    </UserControl.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="12,12" x:Name="Root">
            <TextBlock Text="检查器" FontWeight="Bold" FontSize="14" Foreground="White" Margin="0,0,0,12"/>

            <!-- Thumbnail -->
            <Image x:Name="ThumbImage" Height="150" Stretch="Uniform" Margin="0,0,0,12"/>

            <!-- File Info -->
            <TextBlock Text="文件信息" FontWeight="SemiBold" Foreground="#FFCCCCCC" Margin="0,0,0,4"/>
            <TextBlock x:Name="FileNameText" Foreground="#FFAAAAAA" FontSize="11" TextWrapping="Wrap"/>
            <TextBlock x:Name="FilePathText" Foreground="#FF777777" FontSize="10" TextWrapping="Wrap" Margin="0,2"/>

            <Separator Margin="0,8" Background="#FF444444"/>

            <!-- EXIF -->
            <TextBlock Text="EXIF" FontWeight="SemiBold" Foreground="#FFCCCCCC" Margin="0,0,0,4"/>
            <TextBlock x:Name="CameraText" Foreground="#FFAAAAAA" FontSize="11"/>
            <TextBlock x:Name="LensText" Foreground="#FFAAAAAA" FontSize="11"/>
            <TextBlock x:Name="ApertureText" Foreground="#FFAAAAAA" FontSize="11"/>
            <TextBlock x:Name="ShutterText" Foreground="#FFAAAAAA" FontSize="11"/>
            <TextBlock x:Name="IsoText" Foreground="#FFAAAAAA" FontSize="11"/>
            <TextBlock x:Name="FocalText" Foreground="#FFAAAAAA" FontSize="11"/>
            <TextBlock x:Name="DateText" Foreground="#FFAAAAAA" FontSize="11"/>

            <Separator Margin="0,8" Background="#FF444444"/>

            <!-- AI Score -->
            <TextBlock Text="AI 评分" FontWeight="SemiBold" Foreground="#FFCCCCCC" Margin="0,0,0,4"/>
            <TextBlock x:Name="OverallText" Foreground="#FFAAAAAA" FontSize="11"/>
            <TextBlock x:Name="SharpnessText" Foreground="#FFAAAAAA" FontSize="11"/>
            <TextBlock x:Name="ExposureText" Foreground="#FFAAAAAA" FontSize="11"/>
            <TextBlock x:Name="CompositionText" Foreground="#FFAAAAAA" FontSize="11"/>
            <TextBlock x:Name="FaceText" Foreground="#FFAAAAAA" FontSize="11"/>

            <Separator Margin="0,8" Background="#FF444444"/>

            <!-- Status -->
            <TextBlock Text="状态" FontWeight="SemiBold" Foreground="#FFCCCCCC" Margin="0,0,0,4"/>
            <TextBlock x:Name="StatusText" FontSize="12" FontWeight="Bold"/>
            <TextBlock x:Name="RatingText" FontSize="14" Foreground="#FFFFC107"/>
        </StackPanel>
    </ScrollViewer>
</UserControl>
