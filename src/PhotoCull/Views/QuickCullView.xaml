<UserControl x:Class="PhotoCull.Views.QuickCullView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:PhotoCull.Views"
             xmlns:conv="clr-namespace:PhotoCull.Converters"
             Background="#FF1E1E1E"
             Focusable="True"
             PreviewKeyDown="OnPreviewKeyDown">
    <UserControl.Resources>
        <conv:BoolToVisibilityConverter x:Key="BoolToVis"/>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Toolbar -->
        <Border Grid.Row="0" Background="#FF252525" Padding="8,6">
            <DockPanel>
                <StackPanel DockPanel.Dock="Left" Orientation="Horizontal">
                    <Button Content="X 淘汰" Click="OnRejectClick" Margin="0,0,4,0"
                            Padding="8,4" Background="#FFE53935" Foreground="White" BorderThickness="0" Cursor="Hand"/>
                    <Button Content="P 保留" Click="OnKeepClick" Margin="0,0,4,0"
                            Padding="8,4" Background="#FF4CAF50" Foreground="White" BorderThickness="0" Cursor="Hand"/>
                    <Button Content="Z 撤销" Click="OnUndoClick" Margin="0,0,4,0"
                            Padding="8,4" Background="#FF555555" Foreground="White" BorderThickness="0" Cursor="Hand"/>
                    <Separator Margin="4,0"/>
                    <TextBlock Text="星级: " Foreground="#FFAAAAAA" VerticalAlignment="Center"/>
                    <Button Content="1" Click="OnRatingClick" Tag="1" Margin="2,0" Padding="6,4"
                            Background="#FF3D3D3D" Foreground="#FFFFC107" BorderThickness="0" Cursor="Hand"/>
                    <Button Content="2" Click="OnRatingClick" Tag="2" Margin="2,0" Padding="6,4"
                            Background="#FF3D3D3D" Foreground="#FFFFC107" BorderThickness="0" Cursor="Hand"/>
                    <Button Content="3" Click="OnRatingClick" Tag="3" Margin="2,0" Padding="6,4"
                            Background="#FF3D3D3D" Foreground="#FFFFC107" BorderThickness="0" Cursor="Hand"/>
                    <Button Content="4" Click="OnRatingClick" Tag="4" Margin="2,0" Padding="6,4"
                            Background="#FF3D3D3D" Foreground="#FFFFC107" BorderThickness="0" Cursor="Hand"/>
                    <Button Content="5" Click="OnRatingClick" Tag="5" Margin="2,0" Padding="6,4"
                            Background="#FF3D3D3D" Foreground="#FFFFC107" BorderThickness="0" Cursor="Hand"/>
                </StackPanel>

                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" HorizontalAlignment="Right">
                    <TextBlock x:Name="CountText" Foreground="#FFAAAAAA" VerticalAlignment="Center" Margin="0,0,8,0"/>
                    <Button Content="下一步 →" Click="OnNextPhaseClick" Padding="8,4"
                            Background="#FF2196F3" Foreground="White" BorderThickness="0" Cursor="Hand"/>
                </StackPanel>
            </DockPanel>
        </Border>

        <!-- Tab Bar -->
        <Grid Grid.Row="1" Background="#FF2A2A2A">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Button x:Name="RejectedTab" Grid.Column="0" Click="OnTabClick" Tag="Rejected"
                    Padding="0,10" BorderThickness="0" Cursor="Hand">
                <TextBlock x:Name="RejectedTabText" FontSize="13"/>
            </Button>
            <Button x:Name="KeptTab" Grid.Column="1" Click="OnTabClick" Tag="Kept"
                    Padding="0,10" BorderThickness="0" Cursor="Hand">
                <TextBlock x:Name="KeptTabText" FontSize="13"/>
            </Button>
        </Grid>

        <!-- Content -->
        <Grid Grid.Row="2">
            <!-- Grid View -->
            <local:PhotoGridView x:Name="Grid"
                                 Visibility="{Binding CullingVm.IsZoomed, Converter={StaticResource BoolToVis}, ConverterParameter=Invert}"/>

            <!-- Detail View -->
            <local:PhotoDetailView x:Name="Detail"
                                   Visibility="{Binding CullingVm.IsZoomed, Converter={StaticResource BoolToVis}}"/>
        </Grid>

        <!-- Bottom Bar: Thumbnail Size Slider -->
        <Border Grid.Row="3" Background="#FF252525" Padding="8,4">
            <DockPanel>
                <TextBlock DockPanel.Dock="Left" Text="缩略图大小" Foreground="#FFAAAAAA" VerticalAlignment="Center"
                           FontSize="11" Margin="0,0,8,0"/>
                <Slider x:Name="ThumbnailSlider" Minimum="80" Maximum="300" Value="300"
                        Width="120" VerticalAlignment="Center"
                        ValueChanged="OnThumbnailSizeChanged"/>
            </DockPanel>
        </Border>
    </Grid>
</UserControl>
