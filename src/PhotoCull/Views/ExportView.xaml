<UserControl x:Class="PhotoCull.Views.ExportView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:conv="clr-namespace:PhotoCull.Converters"
             Background="#FF1E1E1E">
    <UserControl.Resources>
        <conv:BoolToVisibilityConverter x:Key="BoolToVis"/>
        <conv:DoubleToPercentConverter x:Key="PctConv"/>
        <conv:NullToVisibilityConverter x:Key="NullToVis"/>
    </UserControl.Resources>

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="导出" FontSize="24" FontWeight="Bold" Foreground="White" Margin="0,0,0,16"/>

        <!-- Stats -->
        <WrapPanel Grid.Row="1" Margin="0,0,0,16">
            <Border Background="#FF2D2D2D" CornerRadius="8" Padding="16,8" Margin="0,0,8,0">
                <StackPanel>
                    <TextBlock Text="已选照片" Foreground="#FF999999" FontSize="11"/>
                    <TextBlock x:Name="SelectedCountText" FontSize="20" FontWeight="Bold" Foreground="#FF4CAF50"/>
                </StackPanel>
            </Border>
            <Border Background="#FF2D2D2D" CornerRadius="8" Padding="16,8" Margin="0,0,8,0">
                <StackPanel>
                    <TextBlock Text="淘汰照片" Foreground="#FF999999" FontSize="11"/>
                    <TextBlock x:Name="RejectedCountText" FontSize="20" FontWeight="Bold" Foreground="#FFE53935"/>
                </StackPanel>
            </Border>
            <Border Background="#FF2D2D2D" CornerRadius="8" Padding="16,8">
                <StackPanel>
                    <TextBlock Text="总计" Foreground="#FF999999" FontSize="11"/>
                    <TextBlock x:Name="TotalCountText" FontSize="20" FontWeight="Bold" Foreground="White"/>
                </StackPanel>
            </Border>
        </WrapPanel>

        <!-- Options -->
        <StackPanel Grid.Row="2" Margin="0,0,0,16">
            <CheckBox Content="复制文件到目标文件夹" IsChecked="{Binding ExportVm.ExportToFolder}"
                      Foreground="White" Margin="0,4"/>
            <CheckBox Content="移动而非复制" IsChecked="{Binding ExportVm.MoveInsteadOfCopy}"
                      Foreground="White" Margin="16,4,0,4"/>
            <CheckBox Content="生成 XMP sidecar 文件" IsChecked="{Binding ExportVm.ExportXmp}"
                      Foreground="White" Margin="0,4"/>
            <CheckBox Content="生成文件名列表 (file_list.txt)" IsChecked="{Binding ExportVm.ExportFileList}"
                      Foreground="White" Margin="0,4"/>

            <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                <TextBlock Text="最低星级筛选: " Foreground="#FFCCCCCC" VerticalAlignment="Center"/>
                <ComboBox x:Name="MinRatingCombo" SelectedIndex="0" Width="80"
                          SelectionChanged="OnMinRatingChanged">
                    <ComboBoxItem Content="不筛选"/>
                    <ComboBoxItem Content="1 星+"/>
                    <ComboBoxItem Content="2 星+"/>
                    <ComboBoxItem Content="3 星+"/>
                    <ComboBoxItem Content="4 星+"/>
                    <ComboBoxItem Content="5 星"/>
                </ComboBox>
            </StackPanel>

            <StackPanel Orientation="Horizontal" Margin="0,12,0,0">
                <Button Content="选择目标文件夹" Click="OnSelectTargetFolder" Padding="12,6"
                        Background="#FF3D3D3D" Foreground="White" BorderThickness="0" Cursor="Hand"/>
                <TextBlock x:Name="TargetFolderText" Foreground="#FFAAAAAA" VerticalAlignment="Center"
                           Margin="12,0,0,0" TextTrimming="CharacterEllipsis" MaxWidth="400"/>
            </StackPanel>
        </StackPanel>

        <!-- Progress -->
        <StackPanel Grid.Row="3" VerticalAlignment="Top"
                    Visibility="{Binding ExportVm.IsExporting, Converter={StaticResource BoolToVis}}">
            <TextBlock Foreground="#FFCCCCCC" Margin="0,4">
                <Run Text="导出进度: "/><Run Text="{Binding ExportVm.ExportProgress, Converter={StaticResource PctConv}, Mode=OneWay}"/>
            </TextBlock>
            <ProgressBar Value="{Binding ExportVm.ExportProgress, Mode=OneWay}" Maximum="1" Height="8"
                         Foreground="#FF4CAF50" Background="#FF3D3D3D"/>
            <TextBlock Text="{Binding ExportVm.CurrentFileName, Mode=OneWay}" Foreground="#FF777777"
                       FontSize="11" Margin="0,4"/>
        </StackPanel>

        <!-- Complete message -->
        <TextBlock Grid.Row="3" Text="导出完成!" FontSize="18" Foreground="#FF4CAF50"
                   VerticalAlignment="Center" HorizontalAlignment="Center"
                   Visibility="{Binding ExportVm.IsComplete, Converter={StaticResource BoolToVis}}"/>

        <!-- Error -->
        <TextBlock Grid.Row="3" Text="{Binding ExportVm.ErrorMessage}" Foreground="#FFE53935"
                   VerticalAlignment="Top" Margin="0,4"
                   Visibility="{Binding ExportVm.ErrorMessage, Converter={StaticResource NullToVis}}"/>

        <!-- Export Button -->
        <Button Grid.Row="4" Content="开始导出" Padding="16,10" FontSize="14"
                Background="#FF4CAF50" Foreground="White" BorderThickness="0"
                Click="OnExportClick" Cursor="Hand" HorizontalAlignment="Left"/>
    </Grid>
</UserControl>
