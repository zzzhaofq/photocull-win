<UserControl x:Class="PhotoCull.Views.ImportView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:conv="clr-namespace:PhotoCull.Converters"
             AllowDrop="True" Drop="OnDrop" DragOver="OnDragOver"
             Background="#FF1E1E1E">
    <UserControl.Resources>
        <conv:BoolToVisibilityConverter x:Key="BoolToVis"/>
        <conv:DoubleToPercentConverter x:Key="PctConv"/>
    </UserControl.Resources>

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="导入照片" FontSize="24" FontWeight="Bold" Foreground="White" Margin="0,0,0,16"/>

        <!-- Drop Zone / Folder Select -->
        <StackPanel Grid.Row="1" VerticalAlignment="Center" HorizontalAlignment="Center"
                    Visibility="{Binding ImportVm.IsImporting, Converter={StaticResource BoolToVis}, ConverterParameter=Invert}">
            <Border BorderBrush="#FF555555" BorderThickness="2" CornerRadius="12"
                    Padding="48,32" Background="#FF2A2A2A" x:Name="DropZone">
                <StackPanel HorizontalAlignment="Center">
                    <TextBlock Text="将照片文件夹拖拽到此处" FontSize="16" Foreground="#FFAAAAAA"
                               HorizontalAlignment="Center"/>
                    <TextBlock Text="或" FontSize="12" Foreground="#FF777777"
                               HorizontalAlignment="Center" Margin="0,8"/>
                    <Button Content="选择文件夹" Padding="16,8" Click="OnSelectFolder"
                            Background="#FF3D3D3D" Foreground="White" BorderThickness="0"
                            Cursor="Hand"/>
                </StackPanel>
            </Border>

            <!-- Recent Sessions -->
            <TextBlock Text="最近会话" FontWeight="SemiBold" Foreground="#FFCCCCCC" Margin="0,24,0,8"
                       x:Name="RecentLabel" Visibility="Collapsed"/>
            <ListBox x:Name="RecentSessionsList" Background="Transparent" BorderThickness="0"
                     Foreground="White" Visibility="Collapsed"
                     SelectionChanged="OnResumeSession">
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <StackPanel Orientation="Horizontal" Margin="4">
                            <TextBlock Text="{Binding FolderPath}" Foreground="#FFCCCCCC" MaxWidth="300"
                                       TextTrimming="CharacterEllipsis"/>
                            <TextBlock Text=" — " Foreground="#FF777777"/>
                            <TextBlock Text="{Binding TotalCount}" Foreground="#FFAAAAAA"/>
                            <TextBlock Text=" 张" Foreground="#FFAAAAAA"/>
                        </StackPanel>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
        </StackPanel>

        <!-- Progress -->
        <StackPanel Grid.Row="1" VerticalAlignment="Center" HorizontalAlignment="Center" Width="400"
                    Visibility="{Binding ImportVm.IsImporting, Converter={StaticResource BoolToVis}}">
            <TextBlock Text="正在导入..." FontSize="16" Foreground="White" Margin="0,0,0,16"/>

            <TextBlock Foreground="#FFCCCCCC" Margin="0,4">
                <Run Text="提取预览: "/><Run Text="{Binding ImportVm.PreviewProgress, Converter={StaticResource PctConv}, Mode=OneWay}"/>
            </TextBlock>
            <ProgressBar Value="{Binding ImportVm.PreviewProgress, Mode=OneWay}" Maximum="1" Height="8" Margin="0,2,0,8"
                         Foreground="#FF4CAF50" Background="#FF3D3D3D"/>

            <TextBlock Foreground="#FFCCCCCC" Margin="0,4">
                <Run Text="AI 评分: "/><Run Text="{Binding ImportVm.AiProgress, Converter={StaticResource PctConv}, Mode=OneWay}"/>
            </TextBlock>
            <ProgressBar Value="{Binding ImportVm.AiProgress, Mode=OneWay}" Maximum="1" Height="8" Margin="0,2,0,8"
                         Foreground="#FF2196F3" Background="#FF3D3D3D"/>

            <TextBlock Foreground="#FFCCCCCC" Margin="0,4">
                <Run Text="智能分组: "/><Run Text="{Binding ImportVm.GroupingProgress, Converter={StaticResource PctConv}, Mode=OneWay}"/>
            </TextBlock>
            <ProgressBar Value="{Binding ImportVm.GroupingProgress, Mode=OneWay}" Maximum="1" Height="8" Margin="0,2,0,8"
                         Foreground="#FFFF9800" Background="#FF3D3D3D"/>

            <Button Content="取消" Margin="0,16,0,0" Padding="12,6"
                    Background="#FF555555" Foreground="White" BorderThickness="0"
                    Click="OnCancelImport" Cursor="Hand"/>
        </StackPanel>

        <!-- Error -->
        <TextBlock Grid.Row="2" x:Name="ErrorText" Foreground="#FFE53935" Margin="0,8"
                   Visibility="Collapsed"/>
    </Grid>
</UserControl>
