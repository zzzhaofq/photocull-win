<UserControl x:Class="PhotoCull.Views.GroupPickView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:PhotoCull.Views"
             xmlns:conv="clr-namespace:PhotoCull.Converters"
             Background="#FF1E1E1E"
             Focusable="True"
             PreviewKeyDown="OnPreviewKeyDown">
    <UserControl.Resources>
        <conv:BoolToVisibilityConverter x:Key="BoolToVis"/>
        <conv:ByteArrayToImageSourceConverter x:Key="ImgConv"/>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Toolbar -->
        <Border Grid.Row="0" Background="#FF252525" Padding="8,6">
            <DockPanel>
                <StackPanel DockPanel.Dock="Left" Orientation="Horizontal">
                    <Button Content="← 返回筛选" Click="OnBackClick" Padding="8,4" Margin="0,0,4,0"
                            Background="#FF555555" Foreground="White" BorderThickness="0" Cursor="Hand"/>
                    <Button x:Name="AcceptBtn" Content="接受推荐 (Enter)" Click="OnAcceptClick" Padding="8,4" Margin="0,0,4,0"
                            Background="#FF4CAF50" Foreground="White" BorderThickness="0" Cursor="Hand"/>
                    <Button x:Name="ConfirmBtn" Content="确认选择 (Enter)" Click="OnConfirmSelectionClick" Padding="8,4" Margin="0,0,4,0"
                            Background="#FF757575" Foreground="White" BorderThickness="0" Cursor="Hand"
                            IsEnabled="False"/>
                    <Button Content="接受全部推荐" Click="OnAcceptAllClick" Padding="8,4" Margin="0,0,4,0"
                            Background="#FF388E3C" Foreground="White" BorderThickness="0" Cursor="Hand"/>
                    <Button Content="对比 (C)" Click="OnCompareClick" Padding="8,4" Margin="0,0,4,0"
                            Background="#FF2196F3" Foreground="White" BorderThickness="0" Cursor="Hand"/>
                    <Button x:Name="ClearSelectionBtn" Content="撤销已选" Click="OnClearSelectionClick" Padding="8,4" Margin="0,0,4,0"
                            Background="#FFE53935" Foreground="White" BorderThickness="0" Cursor="Hand"
                            Visibility="Collapsed"/>
                    <Button x:Name="MergeBtn" Content="合并分组..." Click="OnMergeClick" Padding="8,4"
                            Background="#FF555555" Foreground="White" BorderThickness="0" Cursor="Hand"/>
                    <Button x:Name="MergeCancelBtn" Content="取消" Click="OnMergeCancelClick" Padding="8,4" Margin="4,0,0,0"
                            Background="#FF555555" Foreground="White" BorderThickness="0" Cursor="Hand"
                            Visibility="Collapsed"/>
                    <Button x:Name="MergeConfirmBtn" Content="合并" Click="OnMergeConfirmClick" Padding="8,4" Margin="4,0,0,0"
                            Background="#FFFF9800" Foreground="White" BorderThickness="0" Cursor="Hand"
                            Visibility="Collapsed" IsEnabled="False"/>
                    <TextBlock x:Name="MergeCountText" Foreground="#FFFFAB40" VerticalAlignment="Center" Margin="8,0,0,0"
                               Visibility="Collapsed"/>
                </StackPanel>

                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" HorizontalAlignment="Right">
                    <TextBlock Text="缩略图" Foreground="#FFAAAAAA" VerticalAlignment="Center" FontSize="11" Margin="0,0,4,0"/>
                    <Slider x:Name="GroupThumbnailSlider" Minimum="80" Maximum="300" Value="300"
                            Width="100" VerticalAlignment="Center" Margin="0,0,12,0"
                            ValueChanged="OnGroupThumbnailSizeChanged"/>
                    <TextBlock x:Name="GroupCountText" Foreground="#FFAAAAAA" VerticalAlignment="Center" Margin="0,0,8,0"/>
                    <Button Content="完成 → 导出" Click="OnFinishClick" Padding="8,4"
                            Background="#FFFF9800" Foreground="White" BorderThickness="0" Cursor="Hand"/>
                </StackPanel>
            </DockPanel>
        </Border>

        <!-- Main: Group List | Group Detail -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="250"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Group List -->
            <Border Grid.Column="0" Background="#FF252525" BorderBrush="#FF333333" BorderThickness="0,0,1,0">
                <DockPanel>
                    <TextBlock DockPanel.Dock="Top" Text="组列表" FontWeight="Bold" Foreground="White"
                               Margin="12,12,12,8"/>
                    <ListBox x:Name="GroupList" Background="Transparent" BorderThickness="0"
                             Foreground="White" SelectionChanged="OnGroupSelectionChanged">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Border Padding="8,6" Margin="2" Background="#FF2D2D2D" CornerRadius="4">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel>
                                            <TextBlock FontSize="12" Foreground="White">
                                                <Run Text="{Binding GroupType, Mode=OneWay}"/>
                                                <Run Text=" ("/>
                                                <Run Text="{Binding Photos.Count, Mode=OneWay}"/>
                                                <Run Text=" 张)"/>
                                            </TextBlock>
                                        </StackPanel>
                                        <TextBlock Grid.Column="1" Text="✓" FontSize="14" Foreground="#FF4CAF50"
                                                   VerticalAlignment="Center"
                                                   Visibility="{Binding IsReviewed, Converter={StaticResource BoolToVis}}"/>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </DockPanel>
            </Border>

            <GridSplitter Grid.Column="1" Width="3" HorizontalAlignment="Center" VerticalAlignment="Stretch"
                          Background="Transparent"/>

            <!-- Group Detail Grid -->
            <Grid Grid.Column="2">
                <!-- Normal grid view -->
                <local:PhotoGridView x:Name="GroupGrid"
                                     Visibility="{Binding CullingVm.IsComparing, Converter={StaticResource BoolToVis}, ConverterParameter=Invert}"/>

                <!-- Compare view -->
                <local:CompareView x:Name="Compare"
                                   Visibility="{Binding CullingVm.IsComparing, Converter={StaticResource BoolToVis}}"/>
            </Grid>
        </Grid>
    </Grid>
</UserControl>
