<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Color Palette -->
    <Color x:Key="BgDark">#FF1E1E1E</Color>
    <Color x:Key="BgMedium">#FF252525</Color>
    <Color x:Key="BgLight">#FF2D2D2D</Color>
    <Color x:Key="BgHover">#FF3D3D3D</Color>
    <Color x:Key="FgPrimary">#FFE0E0E0</Color>
    <Color x:Key="FgSecondary">#FFAAAAAA</Color>
    <Color x:Key="FgMuted">#FF777777</Color>
    <Color x:Key="AccentGreen">#FF4CAF50</Color>
    <Color x:Key="AccentRed">#FFE53935</Color>
    <Color x:Key="AccentBlue">#FF2196F3</Color>
    <Color x:Key="AccentOrange">#FFFF9800</Color>
    <Color x:Key="AccentYellow">#FFFFC107</Color>
    <Color x:Key="Border">#FF444444</Color>

    <SolidColorBrush x:Key="BgDarkBrush" Color="{StaticResource BgDark}"/>
    <SolidColorBrush x:Key="BgMediumBrush" Color="{StaticResource BgMedium}"/>
    <SolidColorBrush x:Key="BgLightBrush" Color="{StaticResource BgLight}"/>
    <SolidColorBrush x:Key="BgHoverBrush" Color="{StaticResource BgHover}"/>
    <SolidColorBrush x:Key="FgPrimaryBrush" Color="{StaticResource FgPrimary}"/>
    <SolidColorBrush x:Key="FgSecondaryBrush" Color="{StaticResource FgSecondary}"/>
    <SolidColorBrush x:Key="BorderBrush" Color="{StaticResource Border}"/>

    <!-- Window Style -->
    <Style TargetType="Window">
        <Setter Property="Background" Value="{StaticResource BgDarkBrush}"/>
        <Setter Property="Foreground" Value="{StaticResource FgPrimaryBrush}"/>
    </Style>

    <!-- Sidebar Button Style -->
    <Style x:Key="SidebarButton" TargetType="Button">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="Foreground" Value="{StaticResource FgSecondaryBrush}"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Padding" Value="12,8"/>
        <Setter Property="HorizontalContentAlignment" Value="Left"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="Bd" Background="{TemplateBinding Background}"
                            Padding="{TemplateBinding Padding}" CornerRadius="4" Margin="4,0">
                        <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                          VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Bd" Property="Background" Value="{StaticResource BgHoverBrush}"/>
                            <Setter Property="Foreground" Value="White"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ScrollBar Dark Theme -->
    <Style TargetType="ScrollBar">
        <Setter Property="Background" Value="Transparent"/>
    </Style>

    <!-- TextBox Dark Theme -->
    <Style TargetType="TextBox">
        <Setter Property="Background" Value="{StaticResource BgLightBrush}"/>
        <Setter Property="Foreground" Value="{StaticResource FgPrimaryBrush}"/>
        <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
        <Setter Property="Padding" Value="6,4"/>
    </Style>

    <!-- ListBox Dark Theme -->
    <Style TargetType="ListBox">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Foreground" Value="{StaticResource FgPrimaryBrush}"/>
    </Style>

    <!-- ProgressBar Theme -->
    <Style TargetType="ProgressBar">
        <Setter Property="Background" Value="{StaticResource BgHoverBrush}"/>
        <Setter Property="Foreground" Value="#FF4CAF50"/>
        <Setter Property="Height" Value="8"/>
    </Style>

    <!-- Separator -->
    <Style TargetType="Separator">
        <Setter Property="Background" Value="{StaticResource BorderBrush}"/>
        <Setter Property="Margin" Value="0,4"/>
    </Style>

</ResourceDictionary>
